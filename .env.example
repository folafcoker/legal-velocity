# ── Upstash Redis ────────────────────────────────────────────────────────────
# 1. Go to https://vercel.com/marketplace and add the Upstash Redis integration.
# 2. Create a Redis database and link it to this project.
# 3. Vercel will inject these two variables automatically on the next deploy.
#    Locally: run `vercel env pull .env.local` to get them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Juro REST (optional — webhook is the default live path) ───────────────────
# JURO_API_KEY is only needed if you set JURO_SYNC_ENABLED=true and call /api/sync-juro.
# Webhook payloads already include smartfields for Slack notifications.
JURO_API_KEY=
# Set to true only when you intentionally want to run /api/sync-juro (uses Juro REST API).
# JURO_SYNC_ENABLED=true

# ── SLA alerts (webhook open turns > 48 business hours) ─────────────────────
# Optional: used by GET /api/sla-webhook-check (Vercel cron every 15m + x-vercel-cron header).
# For manual runs: /api/sla-webhook-check?secret=YOUR_CRON_SECRET
# CRON_SECRET=

# Notify via Slack Bot DM (needs chat:write, im:write, users:read on the bot):
# SLACK_SLA_USER_ID=U0xxxx

# Or use a dedicated incoming webhook (falls back to SLACK_WEBHOOK_URL if unset):
# SLACK_SLA_WEBHOOK_URL=

# ── Slack incoming webhook ───────────────────────────────────────────────────
# Create an incoming webhook in Slack: Apps → Incoming Webhooks → Add New.
# Point it at #x-velocity-legal-pulse (or your channel).
SLACK_WEBHOOK_URL=

# Optional: dedicated webhook for “Legal Pulse” nudges from the Live page (falls back to SLACK_WEBHOOK_URL).
# SLACK_LEGAL_PULSE_WEBHOOK_URL=

# Juro “legal under review” (or similar) view linked from the Legal Pulse Slack message.
# JURO_LEGAL_REVIEW_TABLE_URL=https://app.juro.com/documents/69e231247fee45cc20b50169

# ── Juro webhook secret (optional but recommended) ───────────────────────────
# Set a random string here and enter the same value in Juro's webhook settings
# under "Secret". The webhook handler checks the x-juro-signature header.
JURO_WEBHOOK_SECRET=

# ── History paste (POST /api/juro-paste) ─────────────────────────────────────
# If set, clients must send Authorization: Bearer <token> or x-legal-paste-token.
# Leave unset for local/dev only (not recommended for production).
# LEGAL_PASTE_TOKEN=
